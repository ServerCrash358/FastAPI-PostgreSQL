# Copy to .env for local dev:  cp .env.example .env
# In Kubernetes these come from a ConfigMap (non-secret) + Secret (DATABASE_URL).

APP_NAME=documents-api
APP_ENV=development
LOG_LEVEL=info

# asyncpg DSN. For docker-compose the host is the service name "db".
DATABASE_URL=postgresql://devuser:devpass@localhost:5432/capstone_dev
POOL_MIN_SIZE=2
POOL_MAX_SIZE=10
COMMAND_TIMEOUT=30

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60
CACHE_ENABLED=true
